# ── Raw data (too large for GitHub) ──────────────────────────────────────────
data/raw/

# ── SQLite database (regenerated by pipeline — not committed) ─────────────────
data/processed/*.db

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Environment variables ─────────────────────────────────────────────────────
.env

# ── VS Code ───────────────────────────────────────────────────────────────────
# settings.json is intentionally committed (see .vscode/settings.json)
.vscode/extensions.json
.vscode/*.log

# ── Module outputs that are regenerated ───────────────────────────────────────
module2_analytics/charts/
module4_models/outputs/
module5_planning/outputs/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db